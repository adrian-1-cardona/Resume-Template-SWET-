% Custom commands (ATS / Workday friendly)

% Tighten lists globally (better than sprinkling \vspace everywhere)
\usepackage{enumitem}
\setlist[itemize]{noitemsep, topsep=0.5pt, parsep=0pt, partopsep=0pt}

\newcommand{\resumeItem}[1]{\item \small{#1}}

\newcommand{\classesList}[4]{\item \small{#1 #2 #3 #4}}

% Subheading WITHOUT tabular (prevents Workday column scrambling)
\newcommand{\resumeSubheading}[4]{
  \item
  \textbf{#1}\hfill \textbf{\small #2}\\
  \textit{\small #3}\hfill \textit{\small #4}
}

\newcommand{\resumeSubSubheading}[2]{
  \item
  \textit{\small #1}\hfill \textit{\small #2}
}

% Project heading: explicitly mark as Project (prevents parsing as Experience)
\newcommand{\resumeProjectHeading}[2]{
  \item
  \textbf{#1}  \hfill \emph{\small #2}
}

\renewcommand\labelitemi{$\vcenter{\hbox{\tiny$\bullet$}}$}
\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0in,label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}

\newcommand{\resumeItemListStart}{\begin{itemize}[leftmargin=*]}
\newcommand{\resumeItemListEnd}{\end{itemize}}
